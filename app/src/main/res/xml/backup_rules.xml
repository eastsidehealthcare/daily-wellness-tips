<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
    Rules for Auto Backup for Apps on Android 6.0 (API level 23) and higher.
    This file specifies which files to include in app auto-backups.
    -->
    
    <!-- Exclude everything by default -->
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="file" path="."/>
    <exclude domain="external" path="."/>
    
    <!-- Include only the tips JSON file -->
    <include domain="file" path="assets/tips.json"/>
    
</full-backup-content>